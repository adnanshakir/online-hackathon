# =========================

# Database Configuration

# =========================

MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/my_database?retryWrites=true&w=majority

# =========================

# Server Configuration

# =========================

NODE_ENV=development
PORT=3000

# =========================

# JWT Authentication

# =========================

# Generate using: openssl rand -base64 32

ACCESS_TOKEN_SECRET=replace_with_strong_random_string
ACCESS_TOKEN_EXPIRY=15m

REFRESH_TOKEN_SECRET=replace_with_strong_random_string
REFRESH_TOKEN_EXPIRY=7d

# =========================

# Google OAuth (Cloud Console)

# =========================

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# =========================

# Client Configuration

# =========================

FRONTEND_URL=http://localhost:5173

# =========================

# Email (Nodemailer + Gmail OAuth2)

# =========================

MAIL_SERVICE=gmail
MAIL_CLIENT_ID=your_google_oauth_client_id
MAIL_CLIENT_SECRET=your_google_oauth_client_secret
MAIL_REFRESH_TOKEN=your_google_refresh_token
MAIL_USER=[your_email@gmail.com](mailto:your_email@gmail.com)

# =========================

# AI / External APIs

# =========================

GEMINI_API_KEY=your_gemini_api_key
